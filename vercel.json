{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb"
      }
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/$1"
    }
  ],
  "env": {
    "DATABASE_URL":              "@database_url",
    "JWT_SECRET_KEY":            "@jwt_secret_key",
    "SUPABASE_URL":              "@supabase_url",
    "SUPABASE_SERVICE_KEY":      "@supabase_service_key",
    "SUPABASE_UPLOADS_BUCKET":   "@supabase_uploads_bucket",
    "SUPABASE_TEMPLATES_BUCKET": "@supabase_templates_bucket"
  }
}
